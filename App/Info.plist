	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.verifyblind.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>verifyblind</string>
			</array>
		</dict>
	</array>
	<!-- xcconfig'ten Info.plist'e enjekte edilen build-time config — Config.swift bunları okur -->
	<key>API_BASE_URL</key>
	<string>$(API_BASE_URL)</string>
	<key>CERT_PIN_1</key>
	<string>$(CERT_PIN_1)</string>
	<key>CERT_PIN_2</key>
	<string>$(CERT_PIN_2)</string>
	<key>ENCLAVE_DEVELOPER_PUBLIC_KEY</key>
